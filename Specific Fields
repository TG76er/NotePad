// === EXPORT ONLY SPECIFIC FIELDS TO CSV ===
// List your exact field names here (case-sensitive!)
var fieldsToExport = [
    "Month",
    "Date",
    "DoctorName",        // Change these to your actual field names
    "Money In",
    "Balance Due",        // Calc
    "Total Sale",
    "Discount",
    "Sales Tax",
    "Install Fee",
    "Shipping Cost",
    "Total After Tax",    // Calc
    "Total After Tax And Service",  // Calc
    "Discount Average",   // Calc
    "Referral Source",
    "Comm Referral",
    "DE Service",
    "Ergo Rep",
    "SO Number",
    "Stratus Qty",
    "Universal Qty",
    "Horizon Qty",
    "Terra Qty",
    "Hyg Qty",
];

// Build the header row and data row
var header = [];
var values = [];

for (var i = 0; i < fieldsToExport.length; i++) {
    var fieldName = fieldsToExport[i];
    var field = this.getField(fieldName);
    
    header.push(fieldName);
    
    if (field == null) {
        values.push('""');                    // Empty if field doesn't exist
    } else {
        var val = (field.value || "").toString().replace(/"/g, '""');
        values.push('"' + val + '"');
    }
}


// Create the CSV content
var csvContent = header.join(",") + "\r\n" + values.join(",");

// Export and open in Excel
this.createDataObject("Selected_Form_Data.csv", csvContent);
this.exportDataObject({
    cName: "Selected_Form_Data.csv",
    nLaunch: 2          // 2 = open automatically with Excel (or default app)
});

app.alert("Selected form data exported successfully!\n\nThe CSV file has opened in Excel.\nYou can save it as .xlsx.", 3);
